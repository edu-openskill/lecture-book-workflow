direction: right

classes: {
  process: {
    shape: rectangle
    style: {
      fill: "#eef2ff"
      font-color: "#1e40af"
      stroke: "#2563eb"
      stroke-width: 2
      border-radius: 8
      shadow: true
      font-size: 16
      bold: true
    }
    width: 200
    height: 70
  }
}

A: "router.py\nQueryRouter" {
  class: process
}
B: "mcp_tools.py\n도구(Tool)" {
  class: process
}
C: "agent.py\nReAct 에이전트" {
  class: process
}
D: "python run.py\n복합 질문 테스트" {
  class: process
}

A -> B: {
  style: { stroke: "#2563eb"; stroke-width: 2 }
}
B -> C: {
  style: { stroke: "#2563eb"; stroke-width: 2 }
}
C -> D: {
  style: { stroke: "#2563eb"; stroke-width: 2 }
}
