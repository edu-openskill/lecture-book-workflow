    stroke-width: 2
    border-radius: 8
  }
}
Agent: "ConnectHRAgent\n(실습 2)" {
  style: {
    fill: "#dbeafe"
    font-color: "#1e40af"
    stroke: "#2563eb"
    stroke-width: 3
    font-size: 14
    bold: true
    border-radius: 8
  }
}
Cache: ResponseCache {
  style: {
    fill: "#eef2ff"
    stroke: "#2563eb"
    stroke-width: 2
    font-size: 14
    font-color: "#1e40af"
    bold: true
    border-radius: 8
  }
}
Router: QueryRouter {
  style: {
    fill: "#eef2ff"
    stroke: "#2563eb"
    stroke-width: 2
    font-size: 14
    font-color: "#1e40af"
    bold: true
    border-radius: 8
  }
}
LLM: "에이전트\n(RAG/Agent)" {
  style: {
    fill: "#eef2ff"
    stroke: "#2563eb"
    stroke-width: 2
    font-size: 14
    font-color: "#1e40af"
    bold: true
    border-radius: 8
  }
}
Tracker: TokenTracker {
  style: {
    fill: "#eef2ff"
    stroke: "#2563eb"
    stroke-width: 2
    font-size: 14
    font-color: "#1e40af"
    bold: true
    border-radius: 8
  }
}

User -> Agent: 질문
Agent -> Cache: 캐시 조회
Cache -> Agent: HIT / MISS {
  style.stroke-dash: 5
}
Agent -> Router: 질문 분류 (MISS)
Router -> LLM: 경로별 실행
LLM -> Agent: 결과 {
  style.stroke-dash: 5
}
Agent -> Tracker: 사용량 기록
Agent -> Cache: 결과 저장
Agent -> User: 응답 반환 {
  style.stroke-dash: 5
}
