direction: right

build: "docker build (이미지 생성)" {
  style.fill: "#f0f0f0"
  style.stroke: "#333333"
  style.border-radius: 8

  from: "FROM\n베이스 이미지 선택" {
    style.fill: "#ffffff"
    style.stroke: "#333333"
  }
  run: "RUN\n패키지 설치 등" {
    style.fill: "#ffffff"
    style.stroke: "#333333"
  }
  workdir: "WORKDIR\n작업 경로 설정" {
    style.fill: "#ffffff"
    style.stroke: "#333333"
  }
  copy: "COPY\n파일 복사" {
    style.fill: "#ffffff"
    style.stroke: "#333333"
  }

  from -> run -> workdir -> copy
}

image: 이미지 {
  shape: package
  style.fill: "#ffffff"
  style.stroke: "#333333"
}

run_phase: "docker run (컨테이너 실행)" {
  style.fill: "#f0f0f0"
  style.stroke: "#333333"
  style.border-radius: 8

  ep: "ENTRYPOINT\n메인 프로세스 지정" {
    style.fill: "#ffffff"
    style.stroke: "#333333"
  }
  cmd: "CMD\n기본 명령 (덮어쓰기 가능)" {
    style.fill: "#ffffff"
    style.stroke: "#333333"
  }
}

container: 컨테이너 {
  style.fill: "#ffffff"
  style.stroke: "#333333"
  style.stroke-dash: 5
}

build -> image: "빌드 완료" {
  style.stroke: "#333333"
}
image -> run_phase {
  style.stroke: "#333333"
}
run_phase -> container: "실행" {
  style.stroke: "#333333"
}
