direction: right

dev: 개발자 {
  shape: person
  style.stroke: "#333333"
  style.fill: "#f0f0f0"
}

yml: Deployment(yml) {
  shape: page
  style.fill: "#ffffff"
  style.stroke: "#333333"
}

apply: kubectl apply {
  shape: rectangle
  style.fill: "#f8f8f8"
  style.stroke: "#333333"
}

dep: Deployment {
  style.fill: "#ffffff"
  style.stroke: "#333333"
}

rs: ReplicaSet {
  style.fill: "#ffffff"
  style.stroke: "#333333"
}

pod: Pod (컨테이너) {
  style.fill: "#ffffff"
  style.stroke: "#333333"
}

dev -> yml: 작성 {
  style.stroke: "#333333"
}
yml -> apply -> dep -> rs -> pod {
  style.stroke: "#333333"
}
