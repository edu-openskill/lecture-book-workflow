direction: right

hub: Docker Hub {
  shape: cloud
  style.fill: "#ffffff"
  style.stroke: "#333333"
}

image: 이미지 {
  shape: package
  style.fill: "#ffffff"
  style.stroke: "#333333"
}

container: 컨테이너 {
  style.fill: "#ffffff"
  style.stroke: "#333333"
}

hub -> image: 내려받기 {
  style.stroke: "#333333"
}
image -> container: 실행 {
  style.stroke: "#333333"
}
container -> image: 저장 {
  style.stroke: "#333333"
}
image -> hub: 올리기 {
  style.stroke: "#333333"
}
