direction: right

user: 사용자 {
  shape: person
  style.stroke: "#333333"
  style.fill: "#f0f0f0"
}

ingress: Ingress {
  style.fill: "#ffffff"
  style.stroke: "#333333"
}

frontend: Frontend\n(Nginx) {
  style.fill: "#ffffff"
  style.stroke: "#333333"
}

b1: Backend 1\n(Spring Boot) {
  style.fill: "#ffffff"
  style.stroke: "#333333"
}

b2: Backend 2\n(Spring Boot) {
  style.fill: "#ffffff"
  style.stroke: "#333333"
}

db: DB\n(MySQL) {
  shape: cylinder
  style.fill: "#ffffff"
  style.stroke: "#333333"
}

redis: Redis {
  shape: cylinder
  style.fill: "#ffffff"
  style.stroke: "#333333"
}

user -> ingress {
  style.stroke: "#333333"
}
ingress -> frontend {
  style.stroke: "#333333"
}
frontend -> b1 {
  style.stroke: "#333333"
}
frontend -> b2 {
  style.stroke: "#333333"
}
b1 -> db {
  style.stroke: "#333333"
}
b1 -> redis {
  style.stroke: "#333333"
}
b2 -> db {
  style.stroke: "#333333"
}
b2 -> redis {
  style.stroke: "#333333"
}
