direction: right

browser: 브라우저 {
  shape: rectangle
  style.fill: "#ffffff"
  style.stroke: "#333333"
}

ingress: Ingress {
  shape: hexagon
  style.fill: "#ffffff"
  style.stroke: "#333333"
}

service: Service {
  shape: hexagon
  style.fill: "#ffffff"
  style.stroke: "#333333"
}

pod: Pod {
  style.fill: "#ffffff"
  style.stroke: "#333333"
}

browser -> ingress: HTTP 요청 {
  style.stroke: "#333333"
}
ingress -> service: 경로별 라우팅 {
  style.stroke: "#333333"
}
service -> pod: 트래픽 전달 {
  style.stroke: "#333333"
}
