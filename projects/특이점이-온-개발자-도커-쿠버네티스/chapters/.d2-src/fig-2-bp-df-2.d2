direction: right

dockerfile: Dockerfile {
  shape: page
  style.fill: "#ffffff"
  style.stroke: "#333333"
}

image: 이미지 {
  shape: package
  style.fill: "#ffffff"
  style.stroke: "#333333"
}

ca: 컨테이너 A\n(개발) {
  style.fill: "#ffffff"
  style.stroke: "#333333"
}
cb: 컨테이너 B\n(테스트) {
  style.fill: "#ffffff"
  style.stroke: "#333333"
}
cc: 컨테이너 C\n(운영) {
  style.fill: "#ffffff"
  style.stroke: "#333333"
}

dockerfile -> image: build {
  style.stroke: "#333333"
}
image -> ca: run {
  style.stroke: "#333333"
}
image -> cb: run {
  style.stroke: "#333333"
}
image -> cc: run {
  style.stroke: "#333333"
}
