direction: right

cm: ConfigMap\n(값 변경) {
  style.fill: "#ffffff"
  style.stroke: "#333333"
}

api: Kube API Server\n(저장) {
  style.fill: "#ffffff"
  style.stroke: "#333333"
}

running: 실행 중인 Pod {
  shape: oval
  style.fill: "#ffffff"
  style.stroke: "#333333"
}

newpod: 새 Pod\n(변경된 값 적용) {
  shape: oval
  style.fill: "#ffffff"
  style.stroke: "#333333"
}

cm -> api: kubectl apply {
  style.stroke: "#333333"
}
api -> running: 즉시 반영 X {
  style.stroke-dash: 5
  style.stroke: "#999999"
}
api -> newpod: Pod 재시작 {
  style.stroke: "#333333"
}
