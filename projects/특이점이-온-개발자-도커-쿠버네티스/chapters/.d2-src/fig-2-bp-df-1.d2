direction: right

manual: 수동 방식 {
  style.border-radius: 8
  style.stroke: "#333333"
  style.fill: "#f8f8f8"

  s1: 컨테이너 접속 {
    style.fill: "#ffffff"
    style.stroke: "#333333"
  }
  s2: apt install {
    style.fill: "#ffffff"
    style.stroke: "#333333"
  }
  s3: 설정 변경 {
    style.fill: "#ffffff"
    style.stroke: "#333333"
  }
  s4: 또 접속... 또 설치... {
    style.fill: "#ffffff"
    style.stroke: "#333333"
  }

  s1 -> s2 -> s3 -> s4 {
    style.stroke: "#333333"
  }
}

auto: 자동 방식 {
  style.border-radius: 8
  style.stroke: "#333333"
  style.fill: "#f8f8f8"

  d1: Dockerfile 한 장 {
    shape: page
    style.fill: "#ffffff"
    style.stroke: "#333333"
  }
  d2: docker build {
    style.fill: "#ffffff"
    style.stroke: "#333333"
  }
  d3: 끝 {
    style.fill: "#ffffff"
    style.stroke: "#333333"
  }

  d1 -> d2 -> d3 {
    style.stroke: "#333333"
  }
}
